# Configuración de npm para el proyecto
# No ejecutar scripts de instalación para evitar posibles problemas de seguridad
ignore-scripts=true
# Habilitar la auditoría de seguridad para detectar vulnerabilidades en las dependencias
audit=true
# No mostrar mensajes de advertencia sobre paquetes obsoletos
fund=false
# Forzar el uso de versiones compatibles con el motor de Node.js
engine-strict=true

# npm security best practices
# Source: https://github.com/lirantal/npm-security-best-practices

# SECURITY: reject git-source dependencies (git+ssh:// etc)
allow-git=none

# SECURITY: block packages newer than 30 days
min-release-age=3